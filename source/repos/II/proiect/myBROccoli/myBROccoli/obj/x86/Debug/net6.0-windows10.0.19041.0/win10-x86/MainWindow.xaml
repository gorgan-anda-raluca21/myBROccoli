<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="myBROccoli.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:myBROccoli"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0.0" />
                <GradientStop Color="#A2C4B0" Offset="0.3" />
                <GradientStop Color="#1A3A26" Offset="0.7" />
                <GradientStop Color="#000000" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Canvas Opacity="0.04">
            <Canvas.Background>
                <ImageBrush ImageSource="Assets/broccoli_pattern_silhouette.png" 
                            Stretch="None" 
                            AlignmentX="Left" 
                            AlignmentY="Top" />
            </Canvas.Background>
        </Canvas>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Padding="50">

                <Border Background="White" 
                        CornerRadius="24" 
                        Padding="40" 
                        Width="420"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1">

                    <StackPanel Spacing="18">
                        <Image Source="Assets/broccoli_logo.png" 
                               Width="140" Height="140" 
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>

                        <TextBlock Text="Welcome back, Bro!" 
                                   FontSize="32" 
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="Bold" 
                                   HorizontalAlignment="Center"
                                   Foreground="#1B3F22"
                                   CharacterSpacing="12"/>

                        <TextBlock Text="Fuel your gains with greens!" 
                                   FontSize="15"
                                   FontFamily="Segoe UI Variable Text"
                                   Foreground="#556B2F" 
                                   HorizontalAlignment="Center" Margin="0,-12,0,10"/>

                        <TextBox x:ConnectionId='2' x:Name="EmailTextBox" Header="Email Address" PlaceholderText="bro@healthy.com" CornerRadius="8"/>
                        <PasswordBox x:ConnectionId='3' x:Name="PasswordTextBox" Header="Password" PlaceholderText="••••••••" CornerRadius="8"/>

                        <Button x:ConnectionId='4' x:Name="LoginButton"
                                HorizontalAlignment="Stretch" Height="50" CornerRadius="25"
                                Foreground="White" FontSize="16" FontWeight="SemiBold"
                                FontFamily="Segoe UI Variable Display" Margin="0,15,0,0"
                                                         >
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#386B31" Offset="0.0"/>
                                    <GradientStop Color="#234A1F" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <Button.Content>Let's Grow!</Button.Content>
                        </Button>

                        <HyperlinkButton Content="Forgot your seeds (password)?" 
                                         HorizontalAlignment="Center" FontSize="11" Foreground="Gray"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5" Margin="0,10,0,0">
                            <TextBlock Text="New to the garden?" FontSize="12" Foreground="Gray"/>
                            <HyperlinkButton Content="Join the gang" Foreground="#234A1F" FontSize="12" Padding="0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

