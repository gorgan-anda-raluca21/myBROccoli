<Page
    x:Class="myBROccoli.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:myBROccoli"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Page.Transitions>
        <TransitionCollection>
            <NavigationThemeTransition/>
            <EntranceThemeTransition FromHorizontalOffset="40"/>
        </TransitionCollection>
    </Page.Transitions>

    <Page.Resources>
        <Storyboard x:Name="IntroStoryboard">
            <DoubleAnimation Storyboard.TargetName="MainContent"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.7"/>

            <DoubleAnimation Storyboard.TargetName="MainContentTranslate"
                             Storyboard.TargetProperty="X"
                             From="30" To="0" Duration="0:0:0.7"/>
        </Storyboard>
    </Page.Resources>

    <Grid Background="#F6FAF3">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="#1F3A28"
                CornerRadius="0,28,28,0">
            <Grid Padding="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border Width="52"
                            Height="52"
                            CornerRadius="16"
                            Background="#2C5A38">
                        <Image Source="ms-appx:///Assets/broccoli_logo.png"
                               Width="30"
                               Height="30"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="myBROccoli"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="nutrition dashboard"
                                   FontSize="12"
                                   Foreground="#CFE3D2"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Margin="0,40,0,0"
                            Spacing="14">
                    <Border Background="#2D5E3C"
                            CornerRadius="18"
                            Padding="14">
                        <TextBlock Text="🏠 Home"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                    </Border>

                    <Border Background="#274C33"
                            CornerRadius="18"
                            Padding="14">
                        <TextBlock Text="🔥 Weight Loss"
                                   FontSize="16"
                                   Foreground="#DDEBDD"/>
                    </Border>

                    <Border Background="#274C33"
                            CornerRadius="18"
                            Padding="14">
                        <TextBlock Text="💪 Muscle Gain"
                                   FontSize="16"
                                   Foreground="#DDEBDD"/>
                    </Border>

                    <Border Background="#274C33"
                            CornerRadius="18"
                            Padding="14">
                        <TextBlock Text="🍽️ Bulking"
                                   FontSize="16"
                                   Foreground="#DDEBDD"/>
                    </Border>

                    <Border Background="#274C33"
                            CornerRadius="18"
                            Padding="14">
                        <TextBlock Text="📈 Streak Tracker"
                                   FontSize="16"
                                   Foreground="#DDEBDD"/>
                    </Border>
                </StackPanel>

                <Button Grid.Row="2"
                        Content="Logout"
                        Height="44"
                        CornerRadius="18"
                        Background="#DDEFD3"
                        Foreground="#1F3A28"
                        FontWeight="Bold"
                        Click="Logout_Click"/>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto">
            <Grid x:Name="MainContent"
                  Padding="32"
                  Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="MainContentTranslate" X="30"/>
                </Grid.RenderTransform>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- TOP BAR -->
                <Grid Grid.Row="0"
                      Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Welcome back, Bro! 👋"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#183518"/>
                        <TextBlock Text="Your healthy meal planner, tailored to your goal."
                                   FontSize="15"
                                   Foreground="#667085"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="White"
                            BorderBrush="#E2E8E0"
                            BorderThickness="1"
                            CornerRadius="22"
                            Padding="14,10"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Ellipse Width="14" Height="14" Fill="#67C56F"/>
                            <TextBlock Text="Frontend Demo Active"
                                       FontWeight="SemiBold"
                                       Foreground="#2F6B2F"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- HERO + STREAK -->
                <Grid Grid.Row="1"
                      ColumnSpacing="22"
                      Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- HERO -->
                    <Border Grid.Column="0"
                            CornerRadius="32"
                            Padding="30"
                            BorderBrush="#E3EAE0"
                            BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFFFFF" Offset="0.0"/>
                                <GradientStop Color="#EEF8E8" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="16"
                                        MaxWidth="620">
                                <Border Background="#E8F6E1"
                                        CornerRadius="18"
                                        Padding="12,6"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="Smart meals • daily consistency • better habits"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               Foreground="#2F6B2F"/>
                                </Border>

                                <TextBlock Text="Healthy meal ideas for Weight Loss, Muscle Gain and Bulking."
                                           FontSize="34"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           Foreground="#183518"/>

                                <TextBlock Text="myBROccoli helps users discover nutrition ideas based on their objective. The app is designed to make healthy eating feel structured, motivating and easier to follow."
                                           FontSize="15"
                                           TextWrapping="Wrap"
                                           Foreground="#4B5563"/>

                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Background="#F3F8EF"
                                            CornerRadius="18"
                                            Padding="14,8">
                                        <TextBlock Text="Weight Loss"
                                                   Foreground="#234A1F"
                                                   FontWeight="SemiBold"/>
                                    </Border>

                                    <Border Background="#F3F8EF"
                                            CornerRadius="18"
                                            Padding="14,8">
                                        <TextBlock Text="Muscle Gain"
                                                   Foreground="#234A1F"
                                                   FontWeight="SemiBold"/>
                                    </Border>

                                    <Border Background="#F3F8EF"
                                            CornerRadius="18"
                                            Padding="14,8">
                                        <TextBlock Text="Bulking"
                                                   Foreground="#234A1F"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <Grid Grid.Column="1"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                                <Ellipse Width="180"
                                         Height="180"
                                         Fill="#DDF0D4"/>
                                <Ellipse Width="140"
                                         Height="140"
                                         Fill="White"/>
                                <Image Source="ms-appx:///Assets/broccoli_logo.png"
                                       Width="82"
                                       Height="82"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- STREAK -->
                    <Border Grid.Column="1"
                            CornerRadius="32"
                            Padding="24"
                            Background="#1F3A28">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Daily Streak"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <Grid HorizontalAlignment="Center">
                                <Ellipse Width="150"
                                         Height="150"
                                         Fill="#2D5E3C"
                                         Stroke="#6FBF73"
                                         StrokeThickness="8"/>

                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="2">
                                    <TextBlock x:Name="StreakTextBlock"
                                               Text="0"
                                               FontSize="40"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               Foreground="White"/>
                                    <TextBlock Text="days"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               Foreground="#D5E7D7"/>
                                </StackPanel>
                            </Grid>

                            <ComboBox x:Name="GoalComboBox"
                                      Header="Today's goal"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Weight Loss"/>
                                <ComboBoxItem Content="Muscle Gain"/>
                                <ComboBoxItem Content="Bulking"/>
                            </ComboBox>

                            <CheckBox x:Name="DailyCheckBox"
                                      Content="I stayed on track today"
                                      Foreground="White"
                                      Checked="DailyCheckBox_Checked"
                                      Unchecked="DailyCheckBox_Unchecked"/>

                            <Border Background="#2C5A38"
                                    CornerRadius="18"
                                    Padding="14">
                                <TextBlock x:Name="MotivationTextBlock"
                                           Text="Check today's progress to build your streak."
                                           TextWrapping="Wrap"
                                           FontSize="13"
                                           Foreground="#E6F2E7"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- GOAL SECTION TITLE -->
                <StackPanel Grid.Row="2"
                            Margin="0,0,0,18">
                    <TextBlock Text="Choose your nutrition path"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#183518"/>
                    <TextBlock Text="Each card opens a dedicated section with a different focus."
                               FontSize="14"
                               Foreground="#667085"/>
                </StackPanel>

                <!-- GOAL CARDS + QUOTE -->
                <Grid Grid.Row="3"
                      ColumnSpacing="22"
                      RowSpacing="22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- WEIGHT LOSS -->
                    <Border x:Name="CardWeightLoss"
                            Grid.Row="0"
                            Grid.Column="0"
                            CornerRadius="30"
                            Padding="24"
                            Background="White"
                            BorderBrush="#DDE6D8"
                            BorderThickness="1.5"
                            PointerEntered="Card_PointerEntered"
                            PointerExited="Card_PointerExited"
                            Tapped="WeightLossCard_Tapped">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="CardWeightLossScale"
                                            ScaleX="1"
                                            ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>

                        <StackPanel Spacing="14">
                            <Border Width="52"
                                    Height="52"
                                    CornerRadius="16"
                                    Background="#ECF8E7">
                                <TextBlock Text="🔥"
                                           FontSize="24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Text="Weight Loss"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#183518"/>

                            <TextBlock Text="Balanced, lighter meal ideas that support fat loss without feeling restrictive."
                                       TextWrapping="Wrap"
                                       FontSize="14"
                                       Foreground="#4B5563"/>

                            <TextBlock Text="Explore section →"
                                       FontWeight="SemiBold"
                                       Foreground="#2F6B2F"/>
                        </StackPanel>
                    </Border>

                    <!-- MUSCLE GAIN -->
                    <Border x:Name="CardMuscleGain"
                            Grid.Row="0"
                            Grid.Column="1"
                            CornerRadius="30"
                            Padding="24"
                            Background="White"
                            BorderBrush="#DDE6D8"
                            BorderThickness="1.5"
                            PointerEntered="Card_PointerEntered"
                            PointerExited="Card_PointerExited"
                            Tapped="MuscleGainCard_Tapped">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="CardMuscleGainScale"
                                            ScaleX="1"
                                            ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>

                        <StackPanel Spacing="14">
                            <Border Width="52"
                                    Height="52"
                                    CornerRadius="16"
                                    Background="#ECF8E7">
                                <TextBlock Text="💪"
                                           FontSize="24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Text="Muscle Gain"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#183518"/>

                            <TextBlock Text="Protein-focused ideas and structured nutrition for strength and muscle building."
                                       TextWrapping="Wrap"
                                       FontSize="14"
                                       Foreground="#4B5563"/>

                            <TextBlock Text="Explore section →"
                                       FontWeight="SemiBold"
                                       Foreground="#2F6B2F"/>
                        </StackPanel>
                    </Border>

                    <!-- BULKING -->
                    <Border x:Name="CardBulking"
                            Grid.Row="0"
                            Grid.Column="2"
                            CornerRadius="30"
                            Padding="24"
                            Background="White"
                            BorderBrush="#DDE6D8"
                            BorderThickness="1.5"
                            PointerEntered="Card_PointerEntered"
                            PointerExited="Card_PointerExited"
                            Tapped="BulkingCard_Tapped">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="CardBulkingScale"
                                            ScaleX="1"
                                            ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>

                        <StackPanel Spacing="14">
                            <Border Width="52"
                                    Height="52"
                                    CornerRadius="16"
                                    Background="#ECF8E7">
                                <TextBlock Text="🍽️"
                                           FontSize="24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Text="Bulking"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#183518"/>

                            <TextBlock Text="Higher-calorie healthy ideas for surplus phases and sustainable growth."
                                       TextWrapping="Wrap"
                                       FontSize="14"
                                       Foreground="#4B5563"/>

                            <TextBlock Text="Explore section →"
                                       FontWeight="SemiBold"
                                       Foreground="#2F6B2F"/>
                        </StackPanel>
                    </Border>

                    <!-- QUOTE CARD -->
                    <Border Grid.Row="1"
                            Grid.ColumnSpan="3"
                            CornerRadius="28"
                            Padding="24"
                            Background="#EEF8E8"
                            BorderBrush="#DAE8D4"
                            BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Quote of the day"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#183518"/>
                            <TextBlock Text="“Small healthy choices, repeated daily, create the biggest transformations.”"
                                       FontSize="16"
                                       FontStyle="Italic"
                                       TextWrapping="Wrap"
                                       Foreground="#4B5563"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>